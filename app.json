{
  "expo": {
    "name": "prickle-app",
    "slug": "prickle-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "prickleapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.lgpark07.prickleapp"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#eed9bd",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.lgpark07.prickleapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#eed9bd",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 180
        }
      ],
      "expo-font",
      "expo-sqlite",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Prickle uses your camera so you can add a photo to a skin entry.",
          "photosPermission": "Prickle uses your photos so you can add a picture to a skin entry."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#a75e5b"
        }
      ],
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "db8cc139-01b9-432d-b366-04ef2e15d26b"
      }
    }
  }
}
