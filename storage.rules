rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /daily-cactus-images/{allPaths=**} {
      allow read: if true;
      allow write: if false; // uploads happen via console, not the client app
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
